# Local authentication is enabled by default. Set false only for explicitly isolated development diagnostics.
THREATSCOPE_AUTH_ENABLED=true
THREATSCOPE_ENV=development

# Generate private values locally; do not commit them. Example generator:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
THREATSCOPE_SESSION_SECRET=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MFA enrollment fails safely while this value is empty.
THREATSCOPE_MFA_ENCRYPTION_KEY=

THREATSCOPE_ALLOWED_ORIGINS=http://localhost:5173
THREATSCOPE_COOKIE_SECURE=false
THREATSCOPE_SESSION_HOURS=8
THREATSCOPE_IDLE_MINUTES=30
THREATSCOPE_LOGIN_MAX_ATTEMPTS=5
THREATSCOPE_LOCKOUT_MINUTES=15

# Optional one-time Docker bootstrap. Leave unset during normal startup and never commit real values.
# THREATSCOPE_BOOTSTRAP_ADMIN_USERNAME=
# THREATSCOPE_BOOTSTRAP_ADMIN_PASSWORD=
# THREATSCOPE_BOOTSTRAP_ADMIN_DISPLAY_NAME=

# Local operational artifacts. These directories are Git-ignored and must be protected by host permissions.
THREATSCOPE_RUNTIME_DIR=./runtime
THREATSCOPE_BACKUP_DIR=./runtime/backups
THREATSCOPE_EXPORT_DIR=./runtime/exports
THREATSCOPE_RELEASE_DIR=./runtime/releases

# Generate with the same Fernet command shown above. Never reuse the MFA key or commit a generated value.
THREATSCOPE_BACKUP_ENCRYPTION_KEY=
THREATSCOPE_REQUIRE_BACKUP_ENCRYPTION=false
THREATSCOPE_MAX_BACKUP_BYTES=2147483648
THREATSCOPE_MAX_IMPORT_BYTES=104857600
THREATSCOPE_BACKUP_MAX_COUNT=20
THREATSCOPE_BACKUP_MAX_AGE_DAYS=90
THREATSCOPE_BACKUP_MIN_KEEP=3
THREATSCOPE_DEMO_MODE=false

# Release-build metadata is normally supplied by a controlled build environment.
THREATSCOPE_APP_VERSION=1.0.0-rc1
THREATSCOPE_BUILD_COMMIT=development
THREATSCOPE_BUILD_TIMESTAMP=local-development
