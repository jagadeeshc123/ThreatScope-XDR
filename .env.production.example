# Copy to an ignored .env.production file and replace every placeholder.
# This template intentionally contains no usable credential or deployment default.
THREATSCOPE_APP_VERSION=<reviewed-release-version>
THREATSCOPE_BUILD_COMMIT=<full-reviewed-git-revision>
THREATSCOPE_BUILD_TIMESTAMP=<utc-build-timestamp>
THREATSCOPE_FRONTEND_BUILD_ID=<frontend-build-identifier>
THREATSCOPE_BACKEND_BUILD_ID=<backend-build-identifier>
THREATSCOPE_PUBLIC_HOST=<public-dns-hostname>
THREATSCOPE_ALLOWED_HOSTS=<comma-separated-exact-hosts>
THREATSCOPE_ALLOWED_ORIGINS=<comma-separated-https-origins>
THREATSCOPE_TRUSTED_PROXY_NETWORKS=<comma-separated-proxy-cidrs>
THREATSCOPE_HTTP_PORT=<host-http-port>
THREATSCOPE_HTTPS_PORT=<host-https-port>
THREATSCOPE_TLS_CERTIFICATE_HOST_FILE=<absolute-certificate-path>
THREATSCOPE_TLS_PRIVATE_KEY_HOST_FILE=<absolute-private-key-path>
THREATSCOPE_SESSION_SECRET_HOST_FILE=<absolute-session-secret-path>
THREATSCOPE_MFA_ENCRYPTION_KEY_HOST_FILE=<absolute-mfa-fernet-key-path>
THREATSCOPE_CONNECTOR_SECRETS_KEY_HOST_FILE=<absolute-connector-fernet-key-path>
THREATSCOPE_BACKUP_ENCRYPTION_KEY_HOST_FILE=<absolute-backup-fernet-key-path>
THREATSCOPE_MAX_REQUEST_BYTES=<reviewed-byte-limit>
THREATSCOPE_MAX_UPLOAD_BYTES=<reviewed-upload-byte-limit>
THREATSCOPE_REQUEST_TIMEOUT_SECONDS=<reviewed-timeout-seconds>
THREATSCOPE_MINIMUM_FREE_BYTES=<reviewed-free-space-floor>
